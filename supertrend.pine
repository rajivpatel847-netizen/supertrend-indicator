//@version=5
indicator("Supertrend Indicator - Indian Stock Market", shorttitle="Supertrend", overlay=true)

// Input Parameters
period = input.int(10, title="ATR Period", minval=1)
multiplier = input.float(3.0, title="ATR Multiplier", minval=0.1)

// Calculate ATR
tr = math.max(high - low, math.max(math.abs(high - close[1]), math.abs(low - close[1])))
atr = ta.sma(tr, period)

// Calculate hl2
hl2 = (high + low) / 2

// Calculate basic bands
basic_ub = hl2 + multiplier * atr
basic_lb = hl2 - multiplier * atr

// Calculate final bands
final_ub = basic_ub < nz(final_ub[1]) or close[1] > nz(final_ub[1]) ? basic_ub : nz(final_ub[1])
final_lb = basic_lb > nz(final_lb[1]) or close[1] < nz(final_lb[1]) ? basic_lb : nz(final_lb[1])

// Determine supertrend
st = na
st := nz(st[1], hl2) == nz(final_ub[1]) ? close <= nz(final_ub[1]) ? nz(final_ub[1]) : nz(final_lb[1]) : close >= nz(final_lb[1]) ? nz(final_lb[1]) : nz(final_ub[1])

// Plot
plot(st, color=st > hl2 ? color.red : color.green, linewidth=2, title="Supertrend")
plot(final_ub, color=color.red, linewidth=1, style=plot.style_dashed, title="Upper Band")
plot(final_lb, color=color.green, linewidth=1, style=plot.style_dashed, title="Lower Band")

// Signals
buy = ta.crossover(close, st)
sell = ta.crossunder(close, st)

plotshape(buy, title="Buy Signal", shape=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), text="BUY", textcolor=color.white, size=size.small)
plotshape(sell, title="Sell Signal", shape=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="SELL", textcolor=color.white, size=size.small)

// Alerts
alertcondition(buy, title="Supertrend Buy Signal", message="Buy Signal Generated")
alertcondition(sell, title="Supertrend Sell Signal", message="Sell Signal Generated")