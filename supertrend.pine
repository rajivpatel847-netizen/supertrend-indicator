//@version=5
indicator("Supertrend", overlay=true)

length = input.int(10, minval=1)
mult = input.float(3.0, minval=0.1)

hl = (high + low) / 2
tr = math.max(high - low, math.max(math.abs(high - close[1]), math.abs(low - close[1])))
atr = ta.sma(tr, length)

// Define all variables before use
var float ub = na
var float lb = na
var float st = na
var int trend = na

ub = hl + mult * atr
lb = hl - mult * atr

if na(ub[1])
    ub := ub
else
    ub := ub < ub[1] or close[1] > ub[1] ? ub : ub[1]

if na(lb[1])
    lb := lb
else
    lb := lb > lb[1] or close[1] < lb[1] ? lb : lb[1]

if na(st[1])
    st := hl
else
    trend := st[1] == ub[1] ? 1 : -1
    st := trend == 1 ? (close <= ub[1] ? ub : lb) : (close >= lb[1] ? lb : ub)

plot(st, "Supertrend", color=st > hl ? color.red : color.green, linewidth=2)
plot(ub, "Upper Band", color=color.red, linewidth=1, style=plot.style_dashed)
plot(lb, "Lower Band", color=color.green, linewidth=1, style=plot.style_dashed)

buy = ta.crossover(close, st)
sell = ta.crossunder(close, st)

plotshape(buy, "Buy", shape.labelup, location.belowbar, color.green, text="BUY")
plotshape(sell, "Sell", shape.labeldown, location.abovebar, color.red, text="SELL")

alertcondition(buy, title="Buy Signal", message="Supertrend Buy")
alertcondition(sell, title="Sell Signal", message="Supertrend Sell")