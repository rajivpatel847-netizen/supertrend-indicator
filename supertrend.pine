//@version=5
indicator("Supertrend Indicator", shorttitle="ST", overlay=true)

// Inputs
period = input.int(10, title="Period", minval=1)
multiplier = input.float(3.0, title="Multiplier", minval=0.1)

// Calculate HL2
hl2 = (high + low) / 2

// Calculate ATR
tr = math.max(high - low, math.max(math.abs(high - close[1]), math.abs(low - close[1])))
atr = ta.sma(tr, period)

// Upper and Lower Basic Bands
upperBand = hl2 + multiplier * atr
lowerBand = hl2 - multiplier * atr

// Final Bands (with var keyword for history)
var upperBandF = na
var lowerBandF = na

upperBandF := math.max(upperBand, nz(upperBandF[1], upperBand))
lowerBandF := math.min(lowerBand, nz(lowerBandF[1], lowerBand))

// Supertrend Direction
var superTrend = na
var trend = 1

if close > nz(upperBandF[1], upperBandF)
    superTrend := lowerBandF
    trend := 1
else if close < nz(lowerBandF[1], lowerBandF)
    superTrend := upperBandF
    trend := -1
else
    superTrend := nz(superTrend[1], hl2)
    trend := nz(trend[1], 1)

// Signals
buySignal = trend == 1 and trend[1] == -1
sellSignal = trend == -1 and trend[1] == 1

// Plot
plot(superTrend, title="Supertrend", color=trend == 1 ? color.green : color.red, linewidth=2)
plot(upperBandF, title="Upper Band", color=color.red, linewidth=1, style=plot.style_dashed)
plot(lowerBandF, title="Lower Band", color=color.green, linewidth=1, style=plot.style_dashed)

// Plot Signals
plotshape(buySignal, title="Buy Signal", shape=shape.labelup, location=location.belowbar, color=color.green, text="BUY", size=size.small)
plotshape(sellSignal, title="Sell Signal", shape=shape.labeldown, location=location.abovebar, color=color.red, text="SELL", size=size.small)

// Alerts
alertcondition(buySignal, title="Supertrend Buy", message="Buy Signal - Supertrend Indicator")
alertcondition(sellSignal, title="Supertrend Sell", message="Sell Signal - Supertrend Indicator")