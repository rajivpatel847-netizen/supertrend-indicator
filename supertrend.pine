//@version=5
indicator("Supertrend", overlay=true)

len = input.int(10, minval=1)
mult = input.float(3.0, minval=0.1)

hl = (high + low) / 2.0
tr = math.max(high - low, math.max(math.abs(high - close[1]), math.abs(low - close[1])))
atr_val = ta.sma(tr, len)

basic_ub = hl + mult * atr_val
basic_lb = hl - mult * atr_val

var float final_ub = na
final_ub := basic_ub < nz(final_ub[1], basic_ub) or close[1] > nz(final_ub[1], basic_ub) ? basic_ub : nz(final_ub[1], basic_ub)

var float final_lb = na
final_lb := basic_lb > nz(final_lb[1], basic_lb) or close[1] < nz(final_lb[1], basic_lb) ? basic_lb : nz(final_lb[1], basic_lb)

var float supertrend = na
supertrend := nz(supertrend[1], hl) == nz(final_ub[1], final_ub) ? close <= nz(final_ub[1], final_ub) ? nz(final_ub[1], final_ub) : nz(final_lb[1], final_lb) : close >= nz(final_lb[1], final_lb) ? nz(final_lb[1], final_lb) : nz(final_ub[1], final_ub)

buy = ta.crossover(close, supertrend)
sell = ta.crossunder(close, supertrend)

plot(supertrend, "Supertrend", color=supertrend > hl ? color.red : color.green, linewidth=2)
plot(final_ub, "Upper Band", color=color.red, linewidth=1, style=plot.style_dashed)
plot(final_lb, "Lower Band", color=color.green, linewidth=1, style=plot.style_dashed)

plotshape(buy, "Buy Signal", shape=shape.labelup, location=location.belowbar, color=color.green, text="BUY")
plotshape(sell, "Sell Signal", shape=shape.labeldown, location=location.abovebar, color=color.red, text="SELL")

alertcondition(buy, title="Buy", message="Supertrend Buy")
alertcondition(sell, title="Sell", message="Supertrend Sell")